# =============================================================================
# INVOICE DECISION TOOL — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it is in .gitignore
#   4. Only commit THIS file (.env.example) with placeholder values
# =============================================================================


# =============================================================================
# BACKEND — FastAPI
# =============================================================================

# Application
ENVIRONMENT=development         # development | production
DEBUG=true                      # Set to false in production
APP_NAME="Invoice Decision Tool"
APP_VERSION=1.0.0

# Database — PostgreSQL (Neon.tech)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://your_user:your_password@your_neon_host:5432/invoicedb

# JWT Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI API
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SECONDS=60

# Supabase Storage (File Storage)
# Get from: https://app.supabase.com → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_BUCKET=invoices
SUPABASE_SIGNED_URL_EXPIRY=3600   # 1 hour in seconds

# CORS — Frontend URL (whitelist only)
FRONTEND_URL=http://localhost:5173   # Change to production URL in prod

# Rate Limiting
RATE_LIMIT_AUTH=60                  # Requests per minute on /auth/* endpoints
RATE_LIMIT_GENERAL=200              # Requests per minute overall

# File Upload
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/webp

# Risk Rules — Default Thresholds (can also be configured via Admin UI)
RISK_AMOUNT_THRESHOLD=50000        # Flag invoices above this amount (HIGH risk)
RISK_CONFIDENCE_THRESHOLD=0.70     # Flag extractions below this confidence (MEDIUM risk)


# =============================================================================
# FRONTEND — React / Vite
# (Prefix with VITE_ so Vite exposes them to the browser)
# =============================================================================

VITE_API_BASE_URL=http://localhost:8000    # Backend URL
VITE_APP_NAME="Invoice Decision Tool"
VITE_APP_VERSION=1.0.0


# =============================================================================
# OPTIONAL — Future Use (Phase 2)
# =============================================================================

# Email Notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
# SMTP_FROM=noreply@yourcompany.com

# Redis (if upgrading from BackgroundTasks to Celery)
# REDIS_URL=redis://localhost:6379/0

# Sentry (Error Monitoring)
# SENTRY_DSN=REPLACE_WITH_YOUR_SENTRY_DSN
