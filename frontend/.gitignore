# =============================================================================
# FRONTEND — .gitignore (React + Vite + TypeScript)
# SECURITY: No passwords, API keys, or secrets should ever be committed
# =============================================================================

# !! SECURITY — NEVER COMMIT THESE !!
.env
.env.*
!.env.example
*.local
.envrc

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Build output
dist/
dist-ssr/
build/
out/
.next/
.nuxt/

# Vite cache
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Testing
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/
playwright-report/
playwright/.cache/

# TypeScript
*.tsbuildinfo

# Caches
.eslintcache
.stylelintcache
.parcel-cache/
.turbo/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db
Desktop.ini
